# This .gitignore file is for Unity projects.
# See https://github.com/github/gitignore/blob/main/Unity.gitignore for a similar reference.

/[Ll]ibrary/
/[Tt]emp/
/[Oo]bj/
/[Bb]uild/
/[Bb]uilds/
/[Ll]ogs/
/[Uu]ser[Ss]ettings/
/[Mm]emoryCaptures/

# Asset meta data should only be ignored when the corresponding asset is also ignored
!/[Aa]ssets/**/*.meta

# Uncomment this line if you wish to ignore the asset store tools plugin
# /[Aa]ssets/AssetStoreTools*

# Autogenerated Jetbrains Rider plugin
/[Aa]ssets/Plugins/Editor/JetBrains*

# Visual Studio cache directory
.vs/
.vshistory/

# Gradle cache directory
.gradle/

# Autogenerated VS/MD/Consulo solution and project files
ExportedObj/
.consulo/
*.csproj
*.unityproj
*.sln
*.suo
*.tmp
*.user
*.userprefs
*.pidb
*.booproj
*.svd
*.pdb
*.mdb
*.opendb
*.VC.db

# Unity3D generated meta files
*.pidb.meta
*.pdb.meta
*.mdb.meta

# Unity3D generated file on crash reports
sysinfo.txt

# Builds
*.apk
*.aab
*.unitypackage
*.app

# Crashlytics generated file
crashlytics-build.properties

# Packed Addressables
/[Aa]ssets/[Aa]ddressable[Aa]ssets[Dd]ata/*/*.bin*

# Temporary auto-generated Android Assets
/[Aa]ssets/[Ss]treamingAssets/aa.meta
/[Aa]ssets/[Ss]treamingAssets/aa/*

# Editor-only debug/build log files this session produced ad hoc
_*.log
_*.xml

# Claude Code local runtime state (personal/machine-specific, not meant to be shared)
.claude/

# Tooling artifacts
Tools/selfplay.log
Tools/selfplay-results.xml
.superpowers/

# Ad-hoc verification artifacts (any session)
Tools/*.log
Tools/*.xml
Tools/*-results.xml
Tools/build_*
Tools/stdout_*
Tools/*.out
Tools/wait_and_verify_*
Tools/regress_verify_summary.txt
Tools/selfplay-*.txt
Tools/screenshots/

# Unity test-framework scene artifacts (leak from interrupted PlayMode runs)
Assets/InitTestScene*

# Unity crash-recovery scene artifacts
Assets/_Recovery/

# MCP capture output
Assets/Screenshots/
Assets/Screenshots.meta
